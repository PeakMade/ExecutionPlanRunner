# Fabric Administration Hub — environment variables
# Copy this to .env and fill in your values

# ── Fabric workspace ───────────────────────────────────────────────────────────
FABRIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
FABRIC_WORKSPACE_NAME=My Workspace

# ── DW endpoints (shared endpoint for all warehouses in the same workspace) ───
FABRIC_DW_ENDPOINT=<your-workspace-id>.datawarehouse.fabric.microsoft.com
FABRIC_SQL_ENDPOINT=<your-workspace-id>.database.fabric.microsoft.com

# ── WH_STAGING ─────────────────────────────────────────────────────────────────
FABRIC_WH_STAGING=<endpoint>
FABRIC_WH_STAGING_ARTIFACT_ID=00000000-0000-0000-0000-000000000000
FABRIC_WH_STAGING_CONN_ID=00000000-0000-0000-0000-000000000000

# ── WH_ODS ─────────────────────────────────────────────────────────────────────
FABRIC_WH_ODS=<endpoint>
FABRIC_WH_ODS_ARTIFACT_ID=00000000-0000-0000-0000-000000000000
FABRIC_WH_ODS_CONN_ID=00000000-0000-0000-0000-000000000000

# ── WH_PROD2 ───────────────────────────────────────────────────────────────────
FABRIC_WH_PROD2=<endpoint>
FABRIC_WH_PROD2_ARTIFACT_ID=00000000-0000-0000-0000-000000000000
FABRIC_WH_PROD2_CONN_ID=00000000-0000-0000-0000-000000000000

# ── DB_APP_SUPPORT ─────────────────────────────────────────────────────────────
FABRIC_DB_APP_SUPPORT=<endpoint>
FABRIC_DB_APP_SUPPORT_ARTIFACT_ID=00000000-0000-0000-0000-000000000000
FABRIC_DB_APP_SUPPORT_CONN_ID=00000000-0000-0000-0000-000000000000
FABRIC_DB_APP_SUPPORT_CATALOG=DB_APP_SUPPORT

# ── DB_BI_SUPPORT ──────────────────────────────────────────────────────────────
FABRIC_DB_BI_SUPPORT=<endpoint>
FABRIC_DB_BI_SUPPORT_ARTIFACT_ID=00000000-0000-0000-0000-000000000000
FABRIC_DB_BI_SUPPORT_CONN_ID=00000000-0000-0000-0000-000000000000
FABRIC_DB_BI_SUPPORT_CATALOG=DB_BI_SUPPORT

# ── Optional Flask secret key ──────────────────────────────────────────────────
# SECRET_KEY=change-me-in-production
